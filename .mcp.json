{
  "mcpServers": {
    "abyssal-worker": {
      "command": "node",
      "args": [
        "C:/Users/Critek/.claude/plugins/abyssal-worker/server.mjs"
      ],
      "env": {
        "OLLAMA_HOST": "http://localhost:11434"
      }
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--no-performance-crux"
      ],
      "env": {
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1"
      }
    },
    "cratesio": {
      "command": "C:/Users/Critek/.cargo/bin/cratesio-mcp.exe",
      "args": []
    },
    "probe": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@probelabs/probe@latest",
        "mcp"
      ]
    }
  }
}
