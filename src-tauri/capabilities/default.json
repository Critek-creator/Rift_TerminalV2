{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for main, cockpit-detached, and notification pop-out windows. Window controls (minimize/maximize/close) granted so the custom TitleBar.svelte buttons fire. Webview-create granted so cockpit_detach (Phase 6.4) can spawn the detached cockpit window.",
  "windows": ["main", "cockpit-detached", "notif-detached-0", "notif-detached-1", "notif-detached-2", "notif-detached-3"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-outer-position",
    "core:window:allow-outer-size",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:webview:allow-create-webview-window",
    "core:event:default",
    "dialog:default",
    "updater:default"
  ]
}
