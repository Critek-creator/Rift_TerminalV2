{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rift",
  "version": "0.1.0",
  "identifier": "com.abyssal.rift",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rift",
        "width": 1100,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "signCommand": null,
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "PLACEHOLDER_PUBKEY_RUN_TAURI_SIGNER_GENERATE",
      "endpoints": [
        "https://github.com/Critek-creator/Rift_TerminalV2/releases/latest/download/latest.json"
      ]
    }
  }
}
