{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rift",
  "version": "0.1.2",
  "identifier": "com.abyssal.rift",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rift",
        "width": 1100,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "shadow": true,
        "dragDropEnabled": false
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420 tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "signCommand": null,
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBODAwNDE4RDJGQ0EyQkIKUldTN292elNHQVNBS3FrNnpEZjVBei9Ca0dSSHZIQTVIUGhlUjRMcE1DYysxSFlKUVNmME9nQVUK",
      "endpoints": [
        "https://github.com/Critek-creator/Rift_TerminalV2/releases/latest/download/latest.json"
      ]
    }
  }
}
